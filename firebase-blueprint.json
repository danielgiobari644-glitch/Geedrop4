{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and storage information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "storageUsed": { "type": "number", "description": "Storage used in bytes" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "storageUsed", "createdAt"]
    },
    "File": {
      "title": "File",
      "description": "Metadata for shared files",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "size": { "type": "number" },
        "mimeType": { "type": "string" },
        "ownerId": { "type": "string" },
        "ownerName": { "type": "string" },
        "sharedWith": { "type": "array", "items": { "type": "string" } },
        "groupId": { "type": "string" },
        "downloadUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "size", "ownerId", "downloadUrl", "createdAt"]
    },
    "Group": {
      "title": "Group",
      "description": "A group of users for sharing files and chatting",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "members", "createdAt"]
    },
    "Invite": {
      "title": "Invite",
      "description": "Group invitation",
      "type": "object",
      "properties": {
        "groupId": { "type": "string" },
        "groupName": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "receiverId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["groupId", "senderId", "receiverId", "status", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "chatId": { "type": "string", "description": "Group ID or composite ID for 1-on-1" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "fileId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/files/{fileId}": {
      "schema": "File",
      "description": "Shared files metadata"
    },
    "/groups/{groupId}": {
      "schema": "Group",
      "description": "User groups"
    },
    "/invites/{inviteId}": {
      "schema": "Invite",
      "description": "Group invites"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages"
    }
  }
}
